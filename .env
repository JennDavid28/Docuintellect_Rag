# DocuIntellect Configuration

# ── Elasticsearch ──────────────────────────────────────────────────────────────
ES_URL=Your_es_url
ES_INFERENCE_ID=.multilingual-e5-small_linux-x86_64

# ── Groq LLM ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=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
GROQ_TEXT_MODEL=llama-3.1-8b-instant
# Optional: only needed if you use image description inside PDFs/PPTX
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── RAG token limits (safe defaults for Groq free tier: 6000 TPM) ───────────
GROQ_MAX_PROMPT_TOKENS=4200
GROQ_MAX_COMPLETION_TOKENS=900
RAG_MAX_CONTEXT_CHUNKS=8
RAG_MAX_CHARS_PER_CHUNK=900

# ── Whisper (local, runs on your machine — no API key needed) ─────────────────
# base  = good balance for most use cases (~140MB)   <-- recommended
WHISPER_MODEL=base

# ── Text chunking for Elasticsearch indexing ──────────────────────────────────
CHUNK_TOKENS=512
CHUNK_OVERLAP=128

# ── Storage ────────────────────────────────────────────────────────────────────
DB_PATH=./backend/docu_intellect.db
STORAGE_DIR=./storage

# ── Server ─────────────────────────────────────────────────────────────────────
API_PORT=8000
SECRET_KEY=your_api_key

YOUTUBE_COOKIES_FILE=backend/www.youtube.com_cookies.txt
